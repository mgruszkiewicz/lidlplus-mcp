# Lidl Plus locale. Credentials are entered by hand in the browser during
# `lidl-auth`, so there's nothing to store here.
LIDL_COUNTRY=PL
LIDL_LANGUAGE=pl

# Where to keep the refresh token, seen-ticket state, and downloaded receipts.
# Defaults below are relative to the repo root.
LIDL_TOKEN_FILE=./data/refresh_token
LIDL_STATE_FILE=./data/state.json
LIDL_RECEIPTS_DIR=./data/receipts
LIDL_MCP_HOSTNAME="lidlmcp.example.com"

# Transport for `lidl-mcp`: "http" (default) or "stdio".
# LIDL_MCP_TRANSPORT=stdio
